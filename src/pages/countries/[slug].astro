---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { flagUrl } from '../../data/flags';

export async function getStaticPaths() {
	const countries = await getCollection('countriesJa');
	return countries.map((country) => ({
		params: { slug: country.data.slug },
		props: { country },
	}));
}

const { country } = Astro.props;
const { Content } = await render(country);

const themeColor: Record<string, string> = {
	fiscal: 'var(--color-gold)',
	crime:  'var(--color-accent)',
	work:   'var(--color-primary)',
	demo:   'var(--color-teal)',
	edu:    'var(--color-violet)',
};
---

<BaseLayout
	title={country.data.populationShare
		? `${country.data.name}の移民割合は${country.data.populationShare}？公式統計完全解説 | 移民白書`
		: `${country.data.name}の移民統計 — 公式データ完全分析 | 移民白書`}
	lang="ja"
	altHref={`/en/countries/${country.data.slug}/`}
	type="Article"
>

<!-- ── Hero ── -->
<div class="country-hero">
	<div class="hero-badge">公式一次資料のみ · 統計局 · 財務省 · OECD · Eurostat</div>

	<div class="hero-head">
		<img
			class="hero-flag"
			src={flagUrl(country.data.slug, 160)}
			alt=""
			width="72"
			height="54"
		/>
		<h1>{country.data.name}</h1>
	</div>

	{country.data.populationShare && (
		<div class="hero-share">
			<span class="hero-share__label">外国人口比率</span>
			<span class="hero-share__value">{country.data.populationShare}</span>
			{country.data.populationShareSource && (
				<span class="hero-share__source">{country.data.populationShareSource}</span>
			)}
		</div>
	)}

	<p class="hero-sub">移民が{country.data.name}の財政・労働市場・治安・教育に与える影響を、財務省・統計局・OECDなど公式一次資料のみで分析。</p>

	{country.data.keyStats && country.data.keyStats.length > 0 && (
		<div class="hero-stats">
			{country.data.keyStats.map((stat) => (
				<a
					href={stat.href ?? '#'}
					class="hstat"
					style={`--dot: ${themeColor[stat.theme ?? 'fiscal'] ?? 'var(--color-primary)'}`}
				>
					<span class="hstat__dot"></span>
					<span class="hstat__value">{stat.value}</span>
					<span class="hstat__label">{stat.label}</span>
					<span class="hstat__source">{stat.source}</span>
				</a>
			))}
		</div>
	)}
</div>

<!-- ── Article content ── -->
<div class="country-page">
	<Content />
</div>

<!-- ── Explore more ── -->
<div class="explore-section">
	<div class="explore-section__header">
		<span class="explore-dot"></span>
		<h2>さらに探索する</h2>
	</div>

	<div class="explore-grid">
		<a href="/themes/comparison-matrix/" class="explore-card">
			<span class="explore-icon">🗂️</span>
			<div>
				<div class="explore-card__title">20カ国比較マトリクス</div>
				<div class="explore-card__desc">全テーマを一覧で比較</div>
			</div>
		</a>
		<a href="/themes/fiscal-cost/" class="explore-card">
			<span class="explore-icon">💰</span>
			<div>
				<div class="explore-card__title">財政コスト比較</div>
				<div class="explore-card__desc">20カ国の財政純負担を横断比較</div>
			</div>
		</a>
		<a href="/themes/crime/" class="explore-card">
			<span class="explore-icon">🔒</span>
			<div>
				<div class="explore-card__title">治安統計</div>
				<div class="explore-card__desc">公式警察・司法省データ</div>
			</div>
		</a>
		<a href="/themes/labour-market/" class="explore-card">
			<span class="explore-icon">📊</span>
			<div>
				<div class="explore-card__title">雇用格差</div>
				<div class="explore-card__desc">移民と現地人の雇用率の差</div>
			</div>
		</a>
		<a href="/themes/demographics/" class="explore-card">
			<span class="explore-icon">🌍</span>
			<div>
				<div class="explore-card__title">人口動態</div>
				<div class="explore-card__desc">20カ国の移民人口比率と将来予測</div>
			</div>
		</a>
		<a href="/themes/country-explorer/" class="explore-card">
			<span class="explore-icon">🔍</span>
			<div>
				<div class="explore-card__title">国別データ探索</div>
				<div class="explore-card__desc">5つの指標を一画面で確認</div>
			</div>
		</a>
	</div>

	{country.data.relatedFaq && country.data.relatedFaq.length > 0 && (
		<div class="faq-links">
			<div class="faq-links__label">📖 関連Q&amp;A</div>
			{country.data.relatedFaq.map((item) => (
				<a href={item.href} class="faq-link">{item.label} →</a>
			))}
		</div>
	)}

	<div class="back-home">
		<a href="/" class="back-btn">← 全国一覧に戻る</a>
	</div>
</div>

</BaseLayout>

<style>
/* ── Hero ── */
.country-hero {
	max-width: 900px;
	margin: 0 auto;
	padding: 3rem 1.5rem 2rem;
	text-align: center;
}

.hero-badge {
	display: inline-block;
	font-size: 0.68rem;
	font-weight: 700;
	letter-spacing: 0.13em;
	text-transform: uppercase;
	color: var(--color-accent);
	background: color-mix(in srgb, var(--color-accent) 10%, transparent);
	border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
	border-radius: 999px;
	padding: 0.32em 1em;
	margin-bottom: 1.6rem;
}

.hero-head {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 1rem;
	margin-bottom: 1rem;
}

.hero-flag {
	border-radius: 4px;
	box-shadow: 0 2px 8px rgba(0,0,0,0.4);
	flex-shrink: 0;
}

.hero-head h1 {
	font-size: clamp(2.2rem, 6vw, 3.8rem);
	font-weight: 900;
	line-height: 1.15;
	margin: 0;
	letter-spacing: -0.02em;
}

.hero-share {
	display: inline-flex;
	flex-direction: column;
	align-items: center;
	gap: 0.2rem;
	background: color-mix(in srgb, var(--color-teal) 10%, transparent);
	border: 1px solid color-mix(in srgb, var(--color-teal) 35%, transparent);
	border-radius: 16px;
	padding: 0.9rem 2.2rem;
	margin: 0.75rem auto 1.25rem;
}

.hero-share__label {
	font-size: 0.65rem;
	font-weight: 700;
	letter-spacing: 0.12em;
	text-transform: uppercase;
	color: var(--color-teal);
	opacity: 0.8;
}

.hero-share__value {
	font-size: 2.6rem;
	font-weight: 900;
	line-height: 1;
	letter-spacing: -0.03em;
	color: var(--color-teal);
}

.hero-share__source {
	font-size: 0.62rem;
	color: var(--color-muted);
	margin-top: 0.15rem;
}

.hero-sub {
	font-size: 0.95rem;
	color: var(--color-ink-soft);
	line-height: 1.8;
	max-width: 34em;
	margin: 0 auto 2rem;
}

/* ── Stat cards ── */
.hero-stats {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
	gap: 0.85rem;
	margin-top: 0.5rem;
	text-align: left;
}

.hstat {
	position: relative;
	display: flex;
	flex-direction: column;
	gap: 0.3rem;
	background: var(--color-surface-raised);
	border: 1px solid var(--color-border);
	border-top: 3px solid var(--dot);
	border-radius: 10px;
	padding: 1.1rem 1.2rem;
	text-decoration: none;
	color: var(--color-ink);
	transition: transform 0.15s, box-shadow 0.15s;
}
.hstat:hover {
	transform: translateY(-3px);
	box-shadow: 0 8px 24px rgba(0,0,0,0.3);
	color: var(--color-ink);
}

.hstat__dot {
	display: none;
}

.hstat__value {
	font-size: 2rem;
	font-weight: 900;
	line-height: 1;
	letter-spacing: -0.02em;
	color: var(--dot);
}

.hstat__label {
	font-size: 0.8rem;
	color: var(--color-ink-soft);
	line-height: 1.45;
}

.hstat__source {
	font-size: 0.65rem;
	color: var(--color-muted);
	margin-top: auto;
	padding-top: 0.5rem;
	border-top: 1px solid var(--color-border);
}

/* ── Article content ── */
.country-page {
	max-width: 880px;
	margin: 0 auto;
	padding: 0 1.5rem 3rem;
}

/* ── Explore section ── */
.explore-section {
	max-width: 900px;
	margin: 0 auto;
	padding: 0 1.5rem 4rem;
	border-top: 1px solid var(--color-border);
	margin-top: 1rem;
}

.explore-section__header {
	display: flex;
	align-items: center;
	gap: 0.7rem;
	margin: 2rem 0 1.25rem;
}

.explore-dot {
	display: inline-block;
	width: 10px;
	height: 10px;
	background: var(--color-accent);
	border-radius: 2px;
	flex-shrink: 0;
}

.explore-section__header h2 {
	font-size: 1.2rem;
	font-weight: 800;
	margin: 0;
}

.explore-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	gap: 0.75rem;
	margin-bottom: 2rem;
}

.explore-card {
	display: flex;
	align-items: center;
	gap: 0.9rem;
	background: var(--color-surface-raised);
	border: 1px solid var(--color-border);
	border-radius: 10px;
	padding: 1rem 1.25rem;
	text-decoration: none;
	color: var(--color-ink);
	transition: transform 0.13s, border-color 0.13s;
}
.explore-card:hover {
	transform: translateY(-2px);
	border-color: var(--color-primary);
	color: var(--color-ink);
}

.explore-icon {
	font-size: 1.5rem;
	flex-shrink: 0;
	line-height: 1;
}

.explore-card__title {
	font-size: 0.9rem;
	font-weight: 700;
	color: var(--color-primary);
}

.explore-card__desc {
	font-size: 0.78rem;
	color: var(--color-muted);
	margin-top: 0.15rem;
}

/* ── FAQ links ── */
.faq-links {
	background: color-mix(in srgb, var(--color-primary) 8%, transparent);
	border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
	border-radius: 10px;
	padding: 1.1rem 1.4rem;
	margin-bottom: 2rem;
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	gap: 0.5rem 1.25rem;
}

.faq-links__label {
	font-size: 0.75rem;
	font-weight: 700;
	color: var(--color-muted);
	text-transform: uppercase;
	letter-spacing: 0.08em;
	width: 100%;
}

.faq-link {
	font-size: 0.88rem;
	font-weight: 600;
	color: var(--color-primary-soft);
	text-decoration: none;
}
.faq-link:hover {
	color: var(--color-accent);
}

/* ── Back home ── */
.back-home {
	display: flex;
	justify-content: center;
}

.back-btn {
	display: inline-flex;
	align-items: center;
	gap: 0.4em;
	background: transparent;
	color: var(--color-ink-soft);
	font-size: 0.88rem;
	font-weight: 600;
	padding: 0.65em 1.4em;
	border: 1px solid var(--color-border);
	border-radius: 8px;
	text-decoration: none;
	transition: border-color 0.15s, color 0.15s;
}
.back-btn:hover {
	border-color: var(--color-primary);
	color: var(--color-primary);
}
</style>
