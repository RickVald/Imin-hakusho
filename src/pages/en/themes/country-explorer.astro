    population: { value: "11.3%", note: "Foreign-born (2023, INSEE)", signal: "yellow" },
    fiscal:     { value: "Not published", note: "No official estimate", signal: "gray" },
    employment: { value: "−16pt", note: "Employment rate gap (INSEE 2023)", signal: "red" },
