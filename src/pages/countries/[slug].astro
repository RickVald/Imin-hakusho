---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { flagUrl } from '../../data/flags';

export async function getStaticPaths() {
	const countries = await getCollection('countriesJa');
	return countries.map((country) => ({
		params: { slug: country.data.slug },
		props: { country },
	}));
}

const { country } = Astro.props;
const { Content } = await render(country);
---

<BaseLayout title={`${country.data.name} の移民統計 | 移民白書`} lang="ja" altHref={`/en/countries/${country.data.slug}/`}>
	<Breadcrumbs items={[{ label: '移民観察', href: '/' }, { label: country.data.name }]} />
	<h1 class="country-title">
		<img class="country-title__flag" src={flagUrl(country.data.slug, 80)} alt="" width="48" height="36" />
		{country.data.name}
	</h1>
	<div class="country-page">
		<Content />
	</div>
</BaseLayout>
