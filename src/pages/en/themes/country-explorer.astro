    education:  { value: "−17pt", note: "PISA 2022 maths gap after ESCS correction", signal: "red" },
    crime:      { value: "—", note: "No disaggregated data", signal: "gray" },
  },
  nl: {
    name: "Netherlands", flag: "nl", slug: "netherlands",
    population: { value: "24.6%", note: "Immigrant-background (2023, CBS)", signal: "red" },
    fiscal:     { value: "Negative (refugees)", note: "Refugee-origin groups show net burden (CPB 2023)", signal: "red" },
    employment: { value: "−15pt", note: "Employment rate gap (CBS 2023)", signal: "red" },
    education:  { value: "−27pt", note: "PISA 2022 maths gap after ESCS correction", signal: "red" },
    crime:      { value: "3×", note: "Non-Western background crime rate (CBS data)", signal: "red" },
  },
  uk: {
    name: "United Kingdom", flag: "gb", slug: "uk",
    population: { value: "19%", note: "Foreign-born (2023, ONS)", signal: "yellow" },
    fiscal:     { value: "Mixed (OBR)", note: "EEA migrants net positive; non-EEA net negative (OBR 2023)", signal: "yellow" },
