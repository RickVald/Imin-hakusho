<style>
  .theme-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .page-header { margin-bottom: 2.5rem; }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .breadcrumb a { color: var(--color-accent); text-decoration: none; }
  .breadcrumb span { margin: 0 0.4rem; }

  h1 {
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    max-width: 80ch;
  }

  .lang-switch { margin-top: 1.25rem; }

  .lang-switch a {
    display: inline-block;
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9rem;
    border: 1px solid var(--color-accent);
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .lang-switch a:hover { background: var(--color-accent); color: var(--color-bg); }

  .table-section { margin-bottom: 3rem; }

  .table-section h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-surface-raised);
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    min-width: 900px;
  }

  .comparison-table thead tr { background: var(--color-surface-raised); }

  .comparison-table thead th {
    padding: 0.85rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .comparison-table tbody tr {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-surface-raised);
    transition: background 0.15s;
  }

  .comparison-table tbody tr:hover {
    background: color-mix(in srgb, var(--color-surface-raised) 60%, transparent);
  }

  .comparison-table tbody tr.alt {
    background: color-mix(in srgb, var(--color-surface-raised) 30%, var(--color-surface));
  }

  .comparison-table tbody tr.alt:hover {
    background: color-mix(in srgb, var(--color-surface-raised) 60%, transparent);
  }

  .comparison-table td {
    padding: 0.75rem 1rem;
    vertical-align: top;
    line-height: 1.5;
  }

  .country-name a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }

  .country-name a:hover { text-decoration: underline; }

  .gap { font-weight: 700; color: #ff9800; font-size: 0.88rem; }

  .no-data {
    color: var(--color-muted);
    font-style: italic;
    font-weight: 400;
  }

  .methodology-note {
    background: var(--color-surface-raised);
    border-radius: 8px;
    padding: 1.5rem 2rem;
    margin-top: 2rem;
  }

  .methodology-note h2 { font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; }

  .methodology-note ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .methodology-note li {
    font-size: 0.9rem;
    line-height: 1.6;
    padding-left: 1.25rem;
    position: relative;
    color: var(--color-text);
  }

  .methodology-note li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>

</BaseLayout>
