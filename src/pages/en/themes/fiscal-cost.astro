    line-height: 1.5;
  }

  .country-name a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }

  .country-name a:hover {
    text-decoration: underline;
  }

  .figure {
    font-weight: 700;
