  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which country has the highest immigrant population share?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Among 20 Western countries tracked by Immigration Factbook, Australia has the highest foreign-born share at approximately 32% (ABS 2024), followed by New Zealand (~28.8%), Switzerland (27.7% foreign nationals, OFS 2023), Canada (~23%), and Germany (25.6% migration background, Destatis 2023). Direct comparison requires caution as countries use different definitions: foreign-born, foreign nationals, or migration background."
        }
      },
      {
        "@type": "Question",
        "name": "Which countries publish official data on immigration's fiscal impact?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Only a handful of countries publish systematic official estimates: Denmark (Finansministeriet, −DKK 16bn/year for all immigrants and descendants, 2023); Norway (SSB/Holmøy & Strøm 2017, −NOK 4.1m/person net present value for group R3); Germany (Ifo Institut 2023, −€2.1bn/year for 2015 refugee cohort); Sweden (Konjunkturinstitutet 2020, +SEK 6bn/year for labour migrants only). France, Belgium, Switzerland, Canada, Australia, and the UK do not publish equivalent annual official estimates."
        }
      }
    ]
  }
  </script>
</main>
