};

const SIGNAL_CLASS = { red: "signal-red", yellow: "signal-yellow", green: "signal-green", gray: "signal-gray" };

const select = document.getElementById("country-select");
const results = document.getElementById("results");
const placeholder = document.getElementById("placeholder");

select.addEventListener("change", () => {
  const code = select.value;
  if (!code) {
    results.classList.add("hidden");
    placeholder.classList.remove("hidden");
    return;
  }
  const d = DATA[code];
  document.getElementById("country-flag").src = `https://flagcdn.com/w40/${d.flag}.png`;
  document.getElementById("country-flag").alt = d.name;
  document.getElementById("country-name").textContent = d.name;
  document.getElementById("country-link").href = `/en/countries/${d.slug}/`;

  for (const key of ["population","fiscal","employment","education","crime"]) {
    const metric = d[key];
    document.getElementById(`val-${key}`).textContent = metric.value;
    document.getElementById(`note-${key}`).textContent = metric.note;
    const card = document.getElementById(`card-${key}`);
    card.className = "metric-card " + (SIGNAL_CLASS[metric.signal] || "");
  }

  results.classList.remove("hidden");
  placeholder.classList.add("hidden");
});
</script>

<style>
.selector-wrapper {
  max-width: 500px;
  margin: 2rem auto;
  padding: 0 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}
.selector-wrapper label {
  font-weight: 700;
  white-space: nowrap;
  color: var(--color-accent);
}
#country-select {
  flex: 1;
  padding: 0.75rem 1rem;
  background: var(--color-surface-raised);
  color: var(--color-text);
  border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
  border-radius: 8px;
  font-size: 1rem;
  cursor: pointer;
}
#country-select:focus { outline: 2px solid var(--color-accent); }
.results {
  max-width: 900px;
  margin: 0 auto 3rem;
  padding: 0 1.5rem;
}
.hidden { display: none; }
.country-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
}
.country-header h2 { font-size: 1.8rem; font-weight: 800; margin: 0; }
.country-detail-link {
  margin-left: auto;
  color: var(--color-accent);
  font-size: 0.9rem;
  text-decoration: none;
  border: 1px solid var(--color-accent);
  padding: 0.3rem 0.8rem;
  border-radius: 6px;
}
.country-detail-link:hover { background: var(--color-accent); color: #fff; }
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.25rem;
}
.metric-card {
  background: var(--color-surface-raised);
  border-radius: 12px;
  padding: 1.5rem;
  border-top: 4px solid var(--color-muted);
  transition: transform 0.15s;
}
.metric-card:hover { transform: translateY(-2px); }
.signal-red    { border-top-color: #e05252; }
.signal-yellow { border-top-color: #d4a017; }
.signal-green  { border-top-color: #4caf7d; }
.signal-gray   { border-top-color: #666; }
.metric-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
.metric-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-muted);
  margin-bottom: 0.5rem;
}
.metric-value {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: 0.4rem;
  line-height: 1.2;
}
.metric-note {
  font-size: 0.78rem;
  color: var(--color-muted);
  line-height: 1.4;
}
.sources-note {
  margin-top: 1.5rem;
  font-size: 0.8rem;
  color: var(--color-muted);
  text-align: center;
}
.placeholder {
  text-align: center;
  padding: 4rem 1rem;
  color: var(--color-muted);
}
.placeholder-icon { font-size: 3rem; margin-bottom: 1rem; }

.static-summary {
  max-width: 1100px;
  margin: 3rem auto 2rem;
  padding: 0 1.5rem;
}
.static-summary h2 {
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 0.4rem;
}
.static-note {
  font-size: 0.8rem;
  color: var(--color-muted);
  margin-bottom: 1rem;
  line-height: 1.5;
}
.table-scroll { overflow-x: auto; }
.summary-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
}
.summary-table th {
  background: color-mix(in srgb, var(--color-accent) 12%, transparent);
  color: var(--color-text);
  font-weight: 700;
  padding: 0.6rem 0.75rem;
  text-align: left;
  border-bottom: 2px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
  white-space: nowrap;
}
.summary-table td {
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid color-mix(in srgb, var(--color-text) 8%, transparent);
  vertical-align: top;
}
.summary-table tr:hover td { background: color-mix(in srgb, var(--color-accent) 5%, transparent); }
.summary-table td:first-child a { color: var(--color-accent); text-decoration: none; font-weight: 600; }
.summary-table td:first-child a:hover { text-decoration: underline; }
</style>
</BaseLayout>
