    population: { value: "12%", note: "外国生まれ（2023年、CSO）", signal: "yellow" },
    fiscal:     { value: "非公開", note: "公式推計なし", signal: "gray" },
    employment: { value: "−6pt", note: "雇用率格差（CSO 2023）", signal: "yellow" },
    education:  { value: "—", note: "データなし", signal: "gray" },
