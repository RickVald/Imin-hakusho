            <td class="gap">+63</td>
            <td class="gap">+34</td>
            <td>Large persistent gap</td>
          </tr>
          <tr class="alt">
            <td class="country-name">Germany</td>
            <td class="gap">+59</td>
            <td class="gap">+32</td>
            <td>Large persistent gap</td>
          </tr>
          <tr>
            <td class="country-name">Denmark</td>
            <td class="gap">+54</td>
            <td class="gap">+28</td>
            <td>Large persistent gap</td>
          </tr>
          <tr class="alt">
            <td class="country-name">Netherlands</td>
            <td class="gap">+58</td>
            <td class="gap">+27</td>
            <td>Large persistent gap</td>
          </tr>
          <tr>
            <td class="country-name">Portugal</td>
            <td class="gap">+32</td>
            <td class="gap">+25</td>
            <td>Moderate persistent gap</td>
          </tr>
          <tr class="alt">
            <td class="country-name">France</td>
            <td class="gap">+51</td>
            <td class="gap">~+20</td>
            <td>Large persistent gap</td>
          </tr>
          <tr>
            <td class="country-name">Switzerland</td>
            <td class="gap">+53</td>
            <td class="gap">+19</td>
            <td>Moderate persistent gap</td>
          </tr>
          <tr class="alt">
            <td class="country-name">Belgium</td>
            <td class="gap">&gt;+55</td>
            <td class="gap">+17</td>
            <td>Moderate persistent gap</td>
          </tr>
          <tr>
            <td class="country-name">Spain</td>
            <td class="gap">+32</td>
            <td class="gap">+7</td>
            <td>Small residual gap</td>
          </tr>
          <tr class="alt">
            <td class="country-name">Italy</td>
            <td class="gap">+30</td>
            <td class="gap-muted">Not significant</td>
            <td>Gap eliminated by ESCS</td>
          </tr>
          <tr>
            <td class="country-name">Ireland</td>
            <td class="gap">+8</td>
            <td class="gap-muted">Not significant</td>
            <td>Gap eliminated by ESCS</td>
          </tr>
          <tr class="alt">
            <td class="country-name">United Kingdom</td>
            <td class="gap-positive">−12</td>
            <td class="gap-positive">−12</td>
            <td>Immigrant advantage</td>
          </tr>
          <tr>
            <td class="country-name">United States</td>
            <td class="gap-muted">Not significant</td>
            <td class="gap-positive">−16</td>
            <td>Immigrant advantage</td>
          </tr>
          <tr class="alt">
            <td class="country-name">New Zealand</td>
            <td class="gap-positive">−16</td>
            <td class="gap-positive">−16</td>
            <td>Immigrant advantage</td>
          </tr>
          <tr>
            <td class="country-name">Australia</td>
            <td class="gap-positive">−26</td>
            <td class="gap-positive">−26</td>
            <td>Immigrant advantage</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="table-note">
      Positive = native-born outperform immigrants. Negative = immigrants outperform native-born.<br/>
      Source: <a href="https://www.oecd.org/en/publications/pisa-2022-results-volume-i_53f23881-en/full-report/immigrant-background-and-student-performance_f469d45e.html" target="_blank" rel="noopener noreferrer">OECD PISA 2022 Results Volume I — Immigrant Background and Student Performance</a>
    </p>
  </section>
</main>

<style>
  .theme-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .breadcrumb a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .breadcrumb span {
    margin: 0 0.4rem;
  }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    max-width: 80ch;
  }

  .intro-sub {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 80ch;
    border-left: 3px solid var(--color-surface-raised);
    padding-left: 1rem;
    margin-top: 0.5rem;
  }

  .lang-switch {
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  .lang-switch a {
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    transition: background 0.15s;
  }

  .lang-switch a:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .charts-section {
    margin-bottom: 3rem;
  }

  .key-figures-row {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .key-figures-row > :global(.key-figure) {
    flex: 1;
    min-width: 200px;
  }

  .chart-note {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-top: 0.75rem;
    margin-bottom: 2rem;
    padding: 0.6rem 1rem;
    background: var(--color-surface-raised);
    border-radius: 4px;
  }

  .methodology-note {
    background: var(--color-surface-raised);
    border-radius: 8px;
    padding: 1.5rem 2rem;
    margin-bottom: 3rem;
  }

  .methodology-note h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .methodology-note ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .methodology-note li {
    font-size: 0.9rem;
    line-height: 1.6;
    padding-left: 1.25rem;
    position: relative;
    color: var(--color-text);
  }

  .methodology-note li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .table-section {
    margin-bottom: 3rem;
  }

  .table-section h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-surface-raised);
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    min-width: 600px;
  }

  .comparison-table thead tr {
    background: var(--color-surface-raised);
  }

  .comparison-table thead th {
    padding: 0.85rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .comparison-table tbody tr {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-surface-raised);
    transition: background 0.15s;
  }

  .comparison-table tbody tr:hover {
    background: color-mix(in srgb, var(--color-surface-raised) 60%, transparent);
  }

  .comparison-table tbody tr.alt {
    background: color-mix(in srgb, var(--color-surface-raised) 30%, var(--color-surface));
  }

  .comparison-table tbody tr.alt:hover {
    background: color-mix(in srgb, var(--color-surface-raised) 60%, transparent);
  }

  .comparison-table td {
    padding: 0.75rem 1rem;
    vertical-align: middle;
    line-height: 1.5;
  }

  .country-name {
    font-weight: 600;
    white-space: nowrap;
  }

  .country-name a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .country-name a:hover {
    text-decoration: underline;
  }

  .gap {
    font-weight: 700;
    color: #e8636b;
  }

  .gap-positive {
    font-weight: 700;
    color: #2dd4bf;
  }

  .gap-muted {
    color: var(--color-muted);
    font-style: italic;
  }

  .table-note {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .table-note a {
    color: var(--color-accent);
  }
</style>

</BaseLayout>
