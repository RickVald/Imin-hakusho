      </tbody>
    </table>
  </section>

  <section>
    <h2>Countries where immigrant students outperform native-born peers</h2>
    <table>
      <thead>
        <tr>
          <th>Country</th>
          <th>Score difference</th>
          <th>Note</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Australia</td><td>+26 pts</td><td>Points-based skilled migration system</td></tr>
        <tr><td>New Zealand</td><td>+16 pts</td><td>Same</td></tr>
        <tr><td>Canada (2nd generation)</td><td>At parity or above</td><td>Points-based immigration</td></tr>
