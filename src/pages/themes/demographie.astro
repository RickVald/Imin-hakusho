  }

  .table-note {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .methodological-note {
    max-width: 800px;
    margin: 3rem auto 2rem;
    padding: 1.5rem 2rem;
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
    border-left: 4px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
  }
  .methodological-note h2 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .methodological-note ul {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .methodological-note li {
    font-size: 0.88rem;
    color: var(--color-muted);
    line-height: 1.55;
  }
</style>

</BaseLayout>
