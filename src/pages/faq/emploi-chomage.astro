<style>
.related-countries {
  max-width: 800px;
  margin: 2.5rem auto 1rem;
  padding: 0 1.5rem;
}
.related-countries h2 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-bottom: 0.75rem;
}
.related-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
}
.related-links a {
  background: var(--color-surface-raised);
  border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  border-radius: 8px;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  color: var(--color-accent);
  text-decoration: none;
  transition: border-color 0.15s;
}
.related-links a:hover { border-color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface)); }
</style>
