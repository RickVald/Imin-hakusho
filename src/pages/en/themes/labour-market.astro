<BaseLayout title="Immigration Employment Gap: 20-Country Official Statistics | Immigration Factbook" lang="en" altHref="/themes/marche-travail/" description="Official employment and unemployment rate gaps between immigrants and native-born populations across 20 Western countries. Primary sources from national statistics offices only.">

<main class="theme-page">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/en/">Immigration Factbook</a> <span>›</span> <span>Compare by Theme</span>
