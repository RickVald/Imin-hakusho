---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="国別移民データ探索ツール | 移民白書" lang="ja" altHref="/en/themes/country-explorer/" description="20カ国から1カ国を選択して、移民が財政・雇用・教育・犯罪・人口に与える影響を5つの指標で即時表示。">

<main class="theme-page">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">移民白書</a> <span>›</span> <span>国別探索</span>
    </nav>
    <h1>国別移民データ — 探索ツール</h1>
    <p class="intro">国を選択すると、移民が財政・雇用・教育・安全・人口に与える影響を公式統計データで即時表示します。</p>
    <div class="lang-switch"><a href="/en/themes/country-explorer/">🌐 English version</a></div>
  </div>

  <div class="selector-wrapper">
    <label for="country-select">国を選択：</label>
    <select id="country-select">
      <option value="">-- 国を選択してください --</option>
      <option value="dk">🇩🇰 デンマーク</option>
      <option value="se">🇸🇪 スウェーデン</option>
      <option value="no">🇳🇴 ノルウェー</option>
      <option value="fi">🇫🇮 フィンランド</option>
      <option value="de">🇩🇪 ドイツ</option>
      <option value="at">🇦🇹 オーストリア</option>
      <option value="ch">🇨🇭 スイス</option>
      <option value="fr">🇫🇷 フランス</option>
      <option value="be">🇧🇪 ベルギー</option>
      <option value="nl">🇳🇱 オランダ</option>
      <option value="uk">🇬🇧 イギリス</option>
      <option value="ie">🇮🇪 アイルランド</option>
      <option value="it">🇮🇹 イタリア</option>
      <option value="es">🇪🇸 スペイン</option>
      <option value="pt">🇵🇹 ポルトガル</option>
      <option value="cz">🇨🇿 チェコ</option>
      <option value="us">🇺🇸 アメリカ</option>
      <option value="ca">🇨🇦 カナダ</option>
      <option value="au">🇦🇺 オーストラリア</option>
      <option value="nz">🇳🇿 ニュージーランド</option>
    </select>
  </div>

  <div id="results" class="results hidden">
    <div class="country-header">
      <img id="country-flag" src="" alt="" width="48" height="36" />
      <h2 id="country-name"></h2>
      <a id="country-link" href="#" class="country-detail-link">詳細ページへ →</a>
    </div>
    <div class="metrics-grid">
      <div class="metric-card" id="card-population">
        <div class="metric-icon">🌍</div>
        <div class="metric-label">移民人口比率</div>
        <div class="metric-value" id="val-population"></div>
        <div class="metric-note" id="note-population"></div>
      </div>
      <div class="metric-card" id="card-fiscal">
        <div class="metric-icon">💴</div>
        <div class="metric-label">財政コスト</div>
        <div class="metric-value" id="val-fiscal"></div>
        <div class="metric-note" id="note-fiscal"></div>
      </div>
      <div class="metric-card" id="card-employment">
        <div class="metric-icon">📊</div>
        <div class="metric-label">雇用格差</div>
        <div class="metric-value" id="val-employment"></div>
        <div class="metric-note" id="note-employment"></div>
      </div>
      <div class="metric-card" id="card-education">
        <div class="metric-icon">📚</div>
        <div class="metric-label">学力格差（PISA）</div>
        <div class="metric-value" id="val-education"></div>
        <div class="metric-note" id="note-education"></div>
      </div>
      <div class="metric-card" id="card-crime">
        <div class="metric-icon">🔒</div>
        <div class="metric-label">犯罪統計</div>
        <div class="metric-value" id="val-crime"></div>
        <div class="metric-note" id="note-crime"></div>
      </div>
    </div>
    <p class="sources-note">すべてのデータは一次公式資料（各国統計局・財務省・OECD・BKA・BRÅ等）に基づきます。</p>
  </div>

  <div id="placeholder" class="placeholder">
    <div class="placeholder-icon">🗺️</div>
    <p>上のメニューから国を選択してください</p>
  </div>
</main>

