            <td class="share">27.7%</td>
            <td>Foreign nationals (permanent residents)</td>
            <td>December 2025</td>
            <td>FSO (Federal Statistical Office)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/canada/">Canada</a></td>
            <td class="share">23.0%</td>
            <td>Immigrants</td>
            <td>2021 Census</td>
            <td>Statistics Canada</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/sweden/">Sweden</a></td>
            <td class="share">21.0%</td>
            <td>Foreign-born</td>
            <td>December 2024</td>
            <td>Statistics Sweden (SCB)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/austria/">Austria</a></td>
            <td class="share">20.5%</td>
            <td>Foreign nationals</td>
            <td>April 2026</td>
            <td>Statistics Austria</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/uk/">United Kingdom</a></td>
            <td class="share">19.0%</td>
            <td>Foreign-born</td>
            <td>June 2024 (ONS estimate)</td>
            <td>ONS (Office for National Statistics)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/norway/">Norway</a></td>
            <td class="share">17.5%</td>
            <td>Immigrants (both parents foreign-born)</td>
            <td>January 2026</td>
            <td>SSB (Statistics Norway)</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/usa/">United States</a></td>
            <td class="share">14.3%</td>
            <td>Foreign-born</td>
            <td>2023 (ACS)</td>
            <td>US Census Bureau</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/portugal/">Portugal</a></td>
            <td class="share">14.0%</td>
            <td>Foreign nationals</td>
            <td>December 2025</td>
            <td>INE (Statistics Portugal)</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/spain/">Spain</a></td>
            <td class="share">13.96%</td>
            <td>Foreign nationals</td>
            <td>January 2025</td>
            <td>INE (National Statistics Institute of Spain)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/belgium/">Belgium</a></td>
            <td class="share">13.8%</td>
            <td>Non-Belgian nationals</td>
            <td>January 2026</td>
            <td>Statbel</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/denmark/">Denmark</a></td>
            <td class="share">12.6%</td>
            <td>Immigrants (descendants 3.7% tracked separately)</td>
            <td>January 2025</td>
            <td>Statistics Denmark (DST)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/ireland/">Ireland</a></td>
            <td class="share">12.0%</td>
            <td>Non-Irish nationals</td>
            <td>2022 Census</td>
            <td>CSO (Central Statistics Office)</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/finland/">Finland</a></td>
            <td class="share">11.7%</td>
            <td>Foreign-origin (1st &amp; 2nd generation)</td>
            <td>December 2025</td>
            <td>Statistics Finland</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/france/">France</a></td>
            <td class="share">11.3%</td>
            <td>Foreign-born (immigrants)</td>
            <td>2024 (provisional)</td>
            <td>INSEE</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/czechia/">Czechia</a></td>
            <td class="share">10.38%</td>
            <td>Foreign nationals</td>
            <td>December 2025</td>
            <td>Czech Statistical Office (ČSÚ)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/italy/">Italy</a></td>
            <td class="share">9.1%</td>
            <td>Foreign nationals</td>
            <td>December 2024</td>
            <td>ISTAT</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/en/countries/netherlands/">Netherlands</a></td>
            <td class="share-pending">~13.5% (ref.)</td>
            <td>Foreign-born (provisional estimate) — methodology changed in 2024, not directly comparable</td>
            <td>2023 estimate</td>
            <td>CBS (Statistics Netherlands)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/germany/">Germany</a></td>
            <td class="share-pending">25.6% (ref. only)</td>
            <td>Migration background (Migrationshintergrund) — see note</td>
            <td>2024 (Mikrozensus)</td>
