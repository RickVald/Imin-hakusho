---
import '../styles/global.css';

interface Props {
	title: string;
	lang: 'ja' | 'en';
	altHref?: string;
	description?: string;
	canonicalUrl?: string;
	type?: 'WebPage' | 'Article' | 'Dataset';
	dateModified?: string;
}

const { title, lang, altHref, description: descriptionProp, canonicalUrl: canonicalUrlProp, type = 'WebPage', dateModified } = Astro.props;

const defaultDescription =
	lang === 'en'
		? 'Immigration data from official sources for 20 Western countries. Fiscal impact, labor market, crime, education, housing — facts only.'
		: '西欧20カ国の移民データを一次公式資料のみで分析。財政・労働・治安・教育・住宅の実態を数字で把握する。';

const description = descriptionProp ?? defaultDescription;
const canonicalUrl = canonicalUrlProp ?? Astro.url.href;

const footerText =
	lang === 'ja'
		? '本サイトの内容はすべて公的機関・研究機関の一次資料に基づきます。各統計の出典は本文中のリンクをご確認ください。'
		: 'All content on this site is based on primary sources from public institutions and research bodies. See in-text links for each source.';
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- SEO de base -->
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="移民白書" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={lang === 'en' ? 'en_US' : 'ja_JP'} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<!-- JSON-LD : WebSite + Organization -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "WebSite",
					"@id": "https://imin-hakusho.com/#website",
					"name": "移民白書",
					"alternateName": "Immigration Factbook",
					"url": "https://imin-hakusho.com",
					"description": "移民が西欧20カ国の財政・労働市場・治安・教育・住宅に与える影響を、公式一次資料のみに基づいて分析するデータベース",
					"inLanguage": ["ja", "en"],
					"potentialAction": {
						"@type": "SearchAction",
						"target": "https://imin-hakusho.com/?s={search_term_string}",
						"query-input": "required name=search_term_string"
					}
				},
				{
					"@type": "Organization",
					"@id": "https://imin-hakusho.com/#organization",
					"name": "移民白書",
					"alternateName": "Immigration Factbook",
					"url": "https://imin-hakusho.com",
					"foundingDate": "2025",
					"description": "西側諸国の移民に関する公式統計を日本語・英語で提供する独立データベース",
					"knowsAbout": ["immigration statistics", "migration data", "OECD", "Eurostat"],
					"publishingPrinciples": "https://imin-hakusho.com/methodologie/"
				}
			]
		})} />

		<!-- JSON-LD : Article ou Dataset selon le type de page -->
		{(type === 'Article' || type === 'Dataset') && (
			<script type="application/ld+json" set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": type,
				"@id": canonicalUrl,
				"url": canonicalUrl,
				"name": title,
				"description": description,
				"inLanguage": lang === 'ja' ? 'ja' : 'en',
				"isPartOf": { "@id": "https://imin-hakusho.com/#website" },
				"publisher": { "@id": "https://imin-hakusho.com/#organization" },
				...(dateModified ? { "dateModified": dateModified } : {}),
				...(type === 'Dataset' ? {
					"creator": { "@id": "https://imin-hakusho.com/#organization" },
					"license": "https://creativecommons.org/licenses/by/4.0/"
				} : {})
			})} />
		)}

		<!-- JSON-LD : BreadcrumbList -->
		{(() => {
			const parts = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
			if (parts.length === 0) return null;
			const labels: Record<string, string> = {
				en: 'Immigration Factbook', themes: lang === 'ja' ? 'テーマ別比較' : 'Themes',
				faq: lang === 'ja' ? 'よくある質問' : 'FAQ', countries: lang === 'ja' ? '国別データ' : 'Countries',
				articles: lang === 'ja' ? '記事' : 'Articles', methodologie: '方法論',
				methodology: 'Methodology', 'a-propos': 'このサイトについて', about: 'About',
			};
			const items = [{ name: lang === 'ja' ? '移民白書' : 'Immigration Factbook', url: lang === 'ja' ? 'https://imin-hakusho.com/' : 'https://imin-hakusho.com/en/' }];
			let path = '';
			for (const part of parts) {
				if (part === 'en') { path = '/en'; continue; }
				path += '/' + part;
				const name = labels[part] ?? part.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
				items.push({ name, url: 'https://imin-hakusho.com' + path + '/' });
			}
			if (items.length < 2) return null;
			return <script type="application/ld+json" set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "BreadcrumbList",
				"itemListElement": items.map((item, i) => ({
					"@type": "ListItem", "position": i + 1, "name": item.name, "item": item.url
				}))
			})} />;
		})()}

		<!-- hreflang bidirectionnel : self + alternate -->
		<link rel="alternate" hreflang={lang} href={canonicalUrl} />
		{altHref && (
			<>
				<link rel="alternate" hreflang={lang === 'ja' ? 'en' : 'ja'} href={altHref} />
				<link rel="alternate" hreflang="x-default" href={lang === 'ja' ? canonicalUrl : altHref} />
			</>
		)}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Sans:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner">
				<a class="site-header__brand" href={lang === 'ja' ? '/' : '/en/'}>
					{lang === 'ja' ? '移民白書' : 'Immigration Factbook'}
				</a>
				{altHref && (
					<a class="site-header__lang" href={altHref}>
						{lang === 'ja' ? 'English' : '日本語'}
					</a>
				)}
			</div>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div class="site-footer__inner">
				<p>{footerText}</p>
				<nav class="footer-nav">
					{lang === 'ja' ? (
						<>
							<a href="/methodologie/">方法論</a>
							<a href="/sources/">一次資料一覧</a>
							<a href="/a-propos/">このサイトについて</a>
						</>
					) : (
						<>
							<a href="/en/methodology/">Methodology</a>
							<a href="/en/sources/">Sources</a>
							<a href="/en/about/">About</a>
						</>
					)}
				</nav>
			</div>
		</footer>
	</body>
</html>
