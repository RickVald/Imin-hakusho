            <td class="share">32.0%</td>
            <td>Foreign-born</td>
            <td>June 2025</td>
            <td>ABS (Australian Bureau of Statistics)</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/en/countries/new-zealand/">New Zealand</a></td>
            <td class="share">28.8%</td>
            <td>Foreign-born</td>
            <td>2023 Census</td>
            <td>Stats NZ</td>
          </tr>
          <tr>
