    education:  { value: "−7pt", note: "PISA 2022 maths gap after ESCS correction", signal: "yellow" },
    crime:      { value: "—", note: "No disaggregated data", signal: "gray" },
  },
  pt: {
    name: "Portugal", flag: "pt", slug: "portugal",
    population: { value: "14%", note: "Foreign-born (2023, INE)", signal: "yellow" },
    fiscal:     { value: "Not published", note: "No official estimate", signal: "gray" },
    employment: { value: "−9pt", note: "Employment rate gap (INE 2023)", signal: "yellow" },
    education:  { value: "−25pt", note: "PISA 2022 maths gap after ESCS correction", signal: "red" },
    crime:      { value: "—", note: "No disaggregated data", signal: "gray" },
  },
  cz: {
    name: "Czech Republic", flag: "cz", slug: "czechia",
    population: { value: "10.4%", note: "Foreign-born (2023, ČSÚ)", signal: "yellow" },
    fiscal:     { value: "Not published", note: "No official estimate", signal: "gray" },
    employment: { value: "−3pt", note: "Employment rate gap (ČSÚ 2023)", signal: "green" },
    education:  { value: "—", note: "No data available", signal: "gray" },
    crime:      { value: "—", note: "No disaggregated data", signal: "gray" },
  },
