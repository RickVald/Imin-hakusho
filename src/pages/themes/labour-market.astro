---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BarChart from '../../components/BarChart.astro';
import KeyFigure from '../../components/KeyFigure.astro';
---

<BaseLayout title="移民の雇用率格差：西側20カ国比較 | 移民白書" lang="ja" altHref="/en/themes/labour-market/" description="西側20カ国における移民と現地人の雇用率・失業率格差を公式統計で比較。各国統計局・労働省の一次資料のみを使用。" type="Dataset">

<main class="theme-page">
  <div class="theme-hero">
    <div class="theme-hero__badge">公式一次資料のみ · 統計局 · 労働省 · Eurostat · OECD</div>
    <h1>移民と現地人の雇用率格差<br><em>20カ国の公式統計比較</em></h1>
    <p class="theme-hero__sub">各国統計局・労働省・国際機関が公表した移民と現地生まれ住民の雇用率・失業率の格差データを集約。「移民」の定義は国によって異なり、直接比較には注意が必要です。</p>
    <div class="theme-hero__meta">
      <a href="/en/themes/labour-market/" class="lang-pill">🌐 View in English</a>
    </div>
  </div>

  <section class="charts-section">
    <div class="key-figures-row">
      <KeyFigure value="+10.5pt" label="スウェーデン：移民と現地人の失業率格差（SCB AKU、2024年）" tone="accent" />
      <KeyFigure value="20〜24pt" label="ベルギー：北アフリカ系移民と現地人の雇用率格差（Statbel、2022年）" tone="accent" />
      <KeyFigure value="31.3%" label="オーストリア：アフガン・シリア・イラク出身者の失業率（Statistik Austria、2024年）" tone="accent" />
    </div>

    <BarChart
      title="失業率：現地人 vs 移民（国別比較、%）"
      unit="%"
      bars={[
        { label: 'スウェーデン：現地人', value: 5.7, note: 'SCB AKU 2024年平均' },
        { label: 'スウェーデン：外国出生者', value: 16.2, note: 'SCB AKU 2024年平均' },
        { label: 'スイス：スイス人', value: 3.3, note: 'OFS 2025年Q2' },
        { label: 'スイス：外国籍者', value: 7.7, note: 'OFS 2025年Q2' },
        { label: 'フランス：移民系譜なし', value: 7.0, note: 'INSEE/DGEF 2024年' },
        { label: 'フランス：移民', value: 12.0, note: 'INSEE/DGEF 2024年' },
        { label: 'ポルトガル：全人口', value: 6.6, note: 'INE 2025年Q1' },
        { label: 'ポルトガル：外国籍者', value: 11.9, note: 'INE 2025年Q1' },
        { label: 'オーストリア：自国籍者', value: 5.7, note: 'Statistik Austria 2024年' },
        { label: 'オーストリア：外国籍者', value: 10.5, note: 'Statistik Austria 2024年' },
        { label: 'オーストリア：アフガン・シリア・イラク系', value: 31.3, note: 'ÖIF 2024年' },
      ]}
      sourceLabel="SCB（スウェーデン）・OFS（スイス）・INSEE・INE・Statistik Austria"
      sourceUrl="/themes/labour-market/"
      sourcePrefix="出典："
    />

    <BarChart
      title="雇用率格差：現地人 vs 移民（国別比較、%）"
      unit="%"
      bars={[
        { label: 'ノルウェー：移民的背景なし', value: 80, note: 'IMDi 2024年' },
        { label: 'ノルウェー：移民', value: 68, note: 'IMDi 2024年' },
        { label: 'フィンランド：フィンランド系', value: 79, note: '統計局 2023年' },
        { label: 'フィンランド：外国出身', value: 70.3, note: '統計局 2023年' },
        { label: 'ベルギー：ベルギー出身', value: 75.8, note: 'Statbel 2022年' },
        { label: 'ベルギー：北アフリカ出身', value: 51.3, note: 'Statbel 2022年' },
        { label: 'オーストリア：移民背景なし', value: 76.4, note: 'Statistik Austria 2024年' },
        { label: 'オーストリア：移民背景あり', value: 69.0, note: 'Statistik Austria 2024年' },
        { label: 'オーストリア：アフガン・シリア・イラク系', value: 44.1, note: 'ÖIF 2024年' },
      ]}
      sourceLabel="各国統計局（各国ページ参照）"
      sourceUrl="/themes/labour-market/"
      sourcePrefix="出典："
    />
  </section>

  <section class="table-section">
    <h2>雇用率・失業率格差：国別公式統計一覧</h2>
    <div class="table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>国</th>
            <th>現地人（雇用率/失業率）</th>
            <th>移民（雇用率/失業率）</th>
            <th>格差</th>
            <th>出典機関</th>
            <th>年</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="country-name"><a href="/countries/ja/denmark/">デンマーク</a></td>
            <td>デンマーク系男性81%・女性78%（雇用率）</td>
            <td>非欧米系移民男性71%・女性61%（雇用率）</td>
            <td class="gap">男性10pt・女性17pt</td>
            <td>デンマーク統計局（RAS登録データ）</td>
            <td>2024年</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/countries/ja/sweden/">スウェーデン</a></td>
            <td>国内出生：雇用率70.0%・失業率5.7%</td>
            <td>外国出生：雇用率65.8%・失業率16.2%</td>
            <td class="gap">雇用率4.2pt差<br/>失業率10.5pt差</td>
            <td>SCB 労働力調査（AKU）</td>
            <td>2024年平均</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/countries/ja/norway/">ノルウェー</a></td>
            <td>移民的背景なし：雇用率80%（20-66歳）</td>
            <td>移民：雇用率68%</td>
            <td class="gap">12pt差</td>
            <td>IMDi（Indikatorrapport 2025）</td>
            <td>2024年</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/countries/ja/finland/">フィンランド</a></td>
            <td>フィンランド系：雇用率79%（20-64歳）</td>
            <td>外国出身：雇用率70.3%</td>
            <td class="gap">8.7pt差（2016年の15pt差から縮小）</td>
            <td>フィンランド統計局</td>
            <td>2023年</td>
          </tr>
          <tr>
            <td class="country-name"><a href="/countries/ja/germany/">ドイツ</a></td>
            <td>全国男性平均：雇用率72%・全国女性平均：70%</td>
            <td>2015年到着難民男性：76%（全国平均超）<br/>難民女性：35%（全国比−35pt）</td>
            <td class="gap">女性に極大格差（−35pt）<br/>男性は難民が全国平均超</td>
            <td>IAB「10 Jahre Fluchtmigration」</td>
            <td>2024年（到着9年後）</td>
          </tr>
          <tr class="alt">
            <td class="country-name"><a href="/countries/ja/france/">フランス</a></td>
